---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.published !== false);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const PAGE_SIZE = 6;
const { page = "1" } = Astro.url.searchParams;
const currentPage = Math.max(1, parseInt(page) || 1);
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const paginatedPosts = allPosts.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
---

<BaseLayout title="Blog" description="Teaching reflections, physics insights, and classroom stories by Robert Kan.">
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <h1 class="mb-2 text-4xl font-bold text-slate-900">Blog</h1>
    <p class="mb-10 text-lg text-slate-600">
      Teaching reflections, physics insights, and stories from the classroom.
    </p>

    {paginatedPosts.length > 0 ? (
      <>
        <div class="space-y-8">
          {paginatedPosts.map((post) => (
            <article class="group border-b border-slate-100 pb-8">
              <a href={`/blog/${post.slug}`} class="block">
                <h2 class="mb-2 text-xl font-bold text-slate-900 transition-colors group-hover:text-primary-600">
                  {post.data.title}
                </h2>
                <p class="mb-2 text-sm text-slate-500">
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <nav class="mt-10 flex items-center justify-center gap-4">
            {currentPage > 1 && (
              <a
                href={`/blog?page=${currentPage - 1}`}
                class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:border-primary-300 hover:text-primary-600"
              >
                ← Previous
              </a>
            )}
            <span class="text-sm text-slate-500">
              Page {currentPage} of {totalPages}
            </span>
            {currentPage < totalPages && (
              <a
                href={`/blog?page=${currentPage + 1}`}
                class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:border-primary-300 hover:text-primary-600"
              >
                Next →
              </a>
            )}
          </nav>
        )}
      </>
    ) : (
      <div class="rounded-xl border border-slate-200 bg-white p-12 text-center shadow-sm">
        <p class="text-lg text-slate-500">Blog posts coming soon. Stay tuned!</p>
      </div>
    )}
  </section>
</BaseLayout>
