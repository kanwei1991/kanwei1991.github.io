---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Home" description="Robert Kan — International school physics educator and photography enthusiast.">
  <!-- Hero -->
  <section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden bg-gradient-to-br from-slate-900 via-primary-900 to-slate-900 px-4">
    <div class="relative z-10 max-w-3xl text-center">
      <h1 class="mb-4 text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
        Robert Kan
      </h1>
      <p class="mb-6 text-xl text-slate-300 sm:text-2xl">
        Physics Educator &amp; Photography Enthusiast
      </p>
      <p class="mb-8 text-lg text-slate-400">
        Teaching physics at an international school. Sharing knowledge, experiments, and the beauty of science through a lens.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="/courses"
          class="rounded-xl bg-white px-6 py-3 font-semibold text-slate-900 shadow-sm transition-all hover:bg-slate-100 hover:shadow-md"
        >
          Explore Courses
        </a>
        <a
          href="/photography"
          class="rounded-xl border border-slate-600 px-6 py-3 font-semibold text-slate-200 transition-all hover:border-slate-500 hover:bg-slate-800"
        >
          View Gallery
        </a>
      </div>
      <div class="mt-10 flex justify-center">
        <SocialLinks />
      </div>
    </div>
  </section>

  <!-- Featured sections -->
  <section class="mx-auto max-w-5xl px-4 py-20 sm:px-6">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Courses card -->
      <a href="/courses" class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md">
        <div class="mb-4 text-3xl">📚</div>
        <h2 class="mb-2 text-xl font-bold text-slate-900 group-hover:text-primary-600">Courses</h2>
        <p class="text-slate-600">AP Physics, IB Physics, and more — structured curriculum resources for the classroom.</p>
      </a>

      <!-- Labs card -->
      <a href="/labs" class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md">
        <div class="mb-4 text-3xl">🔬</div>
        <h2 class="mb-2 text-xl font-bold text-slate-900 group-hover:text-primary-600">Lab Experiments</h2>
        <p class="text-slate-600">Hands-on physics experiments with detailed procedures, data analysis, and insights.</p>
      </a>

      <!-- Photography card -->
      <a href="/photography" class="group rounded-2xl border border-slate-200 bg-white p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-md">
        <div class="mb-4 text-3xl">📷</div>
        <h2 class="mb-2 text-xl font-bold text-slate-900 group-hover:text-primary-600">Photography</h2>
        <p class="text-slate-600">Capturing the world through a lens — landscapes, moments, and the physics of light.</p>
      </a>
    </div>
  </section>

  <!-- Latest blog -->
  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="mb-8 text-2xl font-bold text-slate-900">Latest from the Blog</h2>
      <p class="text-slate-500">Blog posts coming soon. Stay tuned for teaching reflections, physics insights, and more.</p>
    </div>
  </section>
</BaseLayout>
