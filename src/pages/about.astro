---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="About" description="Learn more about Robert Kan — physics educator and photographer.">
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="mb-8 text-4xl font-bold text-slate-900">About Me</h1>

    <div class="mb-10 flex flex-col items-start gap-6 sm:flex-row">
      <!-- Profile photo placeholder -->
      <div class="flex-shrink-0">
        <div class="h-40 w-40 overflow-hidden rounded-full bg-gradient-to-br from-primary-100 to-primary-200 shadow-md sm:h-48 sm:w-48">
          <img
            src="/images/profile.jpg"
            alt="Robert Kan"
            class="h-full w-full object-cover"
            onerror="this.style.display='none'; this.parentElement.classList.add('flex', 'items-center', 'justify-center'); this.parentElement.innerHTML='<span class=\\'text-5xl\\'>👨‍🏫</span>'"
          />
        </div>
      </div>
      <div>
        <h2 class="mb-2 text-2xl font-bold text-slate-900">Robert Kan</h2>
        <p class="mb-4 text-lg text-primary-600">Physics Educator at an International School</p>
        <div class="mb-4 text-slate-600">
          <p class="mb-3">
            I am a physics teacher passionate about making complex concepts accessible and exciting
            for students. With years of experience teaching IB Physics and AP Physics at the
            international school level, I believe in learning through curiosity, experimentation,
            and real-world connections.
          </p>
          <p class="mb-3">
            Beyond the classroom, I love photography — especially capturing the physical world in
            its natural beauty. To me, physics and photography are deeply connected: both are about
            understanding and appreciating light, motion, and the world around us.
          </p>
          <p>
            This website is my space to share course materials, lab experiments, teaching notes,
            and my photographic journey.
          </p>
        </div>
        <SocialLinks />
      </div>
    </div>

    <!-- Teaching Philosophy -->
    <h2 class="mb-4 text-2xl font-bold text-slate-900">Teaching Philosophy</h2>
    <div class="mb-10 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <ul class="space-y-4 text-slate-700">
        <li class="flex gap-3">
          <span class="mt-1 flex-shrink-0 text-primary-500">✦</span>
          <span><strong>Learn by doing</strong> — physics comes alive when students design experiments, make predictions, and analyze real data.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 flex-shrink-0 text-primary-500">✦</span>
          <span><strong>Connect to the world</strong> — from the physics of a rainbow to the mechanics of a soccer ball, relevance drives engagement.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 flex-shrink-0 text-primary-500">✦</span>
          <span><strong>Think like a scientist</strong> — I emphasize critical thinking, problem-solving, and the scientific method over rote memorization.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 flex-shrink-0 text-primary-500">✦</span>
          <span><strong>Every student can excel</strong> — with the right support and mindset, every student can develop a strong intuition for physics.</span>
        </li>
      </ul>
    </div>

    <!-- Experience -->
    <h2 class="mb-4 text-2xl font-bold text-slate-900">Experience</h2>
    <div class="space-y-6">
      <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-bold text-slate-900">Physics Teacher</h3>
        <p class="text-sm text-primary-600">International School — Present</p>
        <p class="mt-2 text-slate-600">Teaching IB Physics and AP Physics, leading lab sessions, mentoring science fair projects.</p>
      </div>
    </div>
  </section>
</BaseLayout>
