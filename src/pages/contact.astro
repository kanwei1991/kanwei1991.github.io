---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout title="Contact" description="Get in touch with Robert Kan.">
  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6">
    <h1 class="mb-4 text-4xl font-bold text-slate-900">Get in Touch</h1>
    <p class="mb-10 text-lg text-slate-600">
      Have a question about physics, teaching, or photography? I'd love to hear from you.
    </p>

    <div class="mb-12 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">Email</h2>
      <p class="text-slate-600" id="email-display">
        Loading email address...
      </p>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">Social Media</h2>
      <p class="mb-4 text-slate-600">Find me on these platforms:</p>
      <SocialLinks size="lg" />
    </div>
  </section>
</BaseLayout>

<script>
  // Obfuscate email from scrapers
  const user = "robert";
  const domain = "kan";
  const tld = "physics.edu";
  document.getElementById("email-display").innerHTML =
    `<a href="mailto:${user}@${domain}${tld}" class="text-primary-600 underline decoration-primary-300 underline-offset-2 hover:text-primary-800">${user}@${domain}${tld}</a>`;
</script>
